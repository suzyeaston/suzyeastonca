---
const { title, label, copy, href, cta, stat, tone = 'green' } = Astro.props;
---
<article class:list={["mission-card", `mission-card--${tone}`]}>
  <div class="mission-card__notch" aria-hidden="true"></div>
  <p class="mission-card__label">{label}</p>
  <h3>{title}</h3>
  <p>{copy}</p>
  <div class="mission-card__footer">
    <span>{stat}</span>
    <a href={href}>{cta}</a>
  </div>
</article>
