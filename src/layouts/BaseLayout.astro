---
import '../styles/home.css';
const { title = 'Suzy Easton — Music, AI Strategy, Creative Technology' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Suzy Easton is a Vancouver-based musician, AI strategist, creative technologist, and builder of useful weird systems." />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Press+Start+2P&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to signal</a>
    <slot />
  </body>
</html>
